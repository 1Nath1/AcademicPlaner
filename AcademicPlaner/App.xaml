<?xml version = "1.0" encoding = "UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:AcademicPlaner"
             x:Class="AcademicPlaner.App">
    <Application.Resources>

        
        <ResourceDictionary>

            <FontImageSource x:Key="CalendarIcon"
                  FontFamily="FontAwesomeSolid"
                  Glyph="&#xf133;"
                  Color="{StaticResource Background_ButtonColor}"
                  Size="60" />

            <FontImageSource x:Key="AssignmentIcon"
                  FontFamily="FontAwesomeSolid"
                  Glyph="&#xf46d;"
                  Color="{StaticResource Background_ButtonColor}"
                  Size="60" />


            <FontImageSource x:Key="AbsenceIcon"
                  FontFamily="FontAwesomeSolid"
                  Glyph="&#xf273;"
                  Color="{StaticResource Background_ButtonColor}"
                  Size="60" />


            <FontImageSource x:Key="WeeklyScheduleIcon"
                  FontFamily="FontAwesomeSolid"
                  Glyph="&#xf784;"
                  Color="{StaticResource Background_ButtonColor}"
                  Size="60" />

            <FontImageSource x:Key="ExamsIcon"
                  FontFamily="FontAwesomeSolid"
                  Glyph="&#xf19d;"
                  Color="{StaticResource Background_ButtonColor}"
                  Size="60" />


            <FontImageSource x:Key="SubjectsIcon"
                  FontFamily="FontAwesomeSolid"
                  Glyph="&#xf518;"
                  Color="{StaticResource Background_ButtonColor}"
                  Size="60" />

            <Color x:Key="PanelColor">#93BAD9</Color>
            <Color x:Key="Background_color">#C7D7E7</Color>
            <Color x:Key="RightPanelColor">#E9C6CE</Color>
            <Color x:Key="Primary">#fff8e7</Color>
            <Color x:Key="Background_ButtonColor">#c492ae</Color>
            
            
            <!--kolory czcionek-->
            <Color x:Key="PrimaryTextColor">#3e7eb1</Color>
            <Color x:Key="SecondaryTextColor">#326690</Color>
            <Color x:Key="TertiaryTextColor">#786254</Color>
            
            
            
            
            <!--styl dla zwyklego tekstu-->
            <Style x:Key="LabelStyle1" TargetType="Label">
                <Setter Property="FontFamily"
            Value="NunitoBold" />
                <Setter Property="TextColor"
            Value="{StaticResource TertiaryTextColor}" />
                <Setter Property="FontSize"
            Value="20" />
                
            </Style>


            <Style x:Key="LabelStyle2" TargetType="Label">
                <Setter Property="FontFamily"
                Value="NunitoBold" />
                <Setter Property="TextColor"
                Value="{StaticResource TertiaryTextColor}" />
                <Setter Property="FontSize"
                Value="16" />

            </Style>

            <!-- styl dla naglowka-->
            <Style x:Key="TitleLabelStyle"
       TargetType="Label">
                <Setter Property="FontFamily"
                Value="NunitoBold" />
                <Setter Property="TextColor"
            Value="{StaticResource PrimaryTextColor}" />

                <Setter Property="FontSize"
            Value="34" />

                

            </Style>




            <!-- styl dla naglowka2-->
            <Style x:Key="TitleLabelStyle2"
            TargetType="Label">
                <Setter Property="FontFamily"
                Value="NunitoBold" />
                <Setter Property="TextColor"
                Value="{StaticResource SecondaryTextColor}" />

                <Setter Property="FontSize"
                 Value="24" />

                <Setter Property="FontAttributes"
     Value="Bold" />

            </Style>



            <!-- styl dla przycisku-->
            <Style x:Key="MenuButtonStyle"
            TargetType="Button">

                <Setter Property="BackgroundColor"
            Value="{StaticResource Background_ButtonColor}" />

                <Setter Property="TextColor"
            Value="{StaticResource Primary}" />

                <Setter Property="FontSize"
            Value="16" />

                <Setter Property="CornerRadius"
            Value="12" />

                
                
                <Setter Property="FontFamily"
            Value="NunitoBold" />
                
               

            </Style>




            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles/Colors.xaml" />
                <ResourceDictionary Source="Resources/Styles/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>
